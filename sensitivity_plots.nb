Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "a", " ", "plotting", " ", "function", " ", "for", " ", 
    "consistent", " ", "frames"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "MakeSensitivityPlot", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MakeSensitivityPlot", "[", 
     RowBox[{"expr_", ",", 
      RowBox[{"{", 
       RowBox[{"xVar_", ",", "xMin_", ",", "xMax_"}], "}"}], ",", "title_", ",",
       "xLabel_"}], "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"Plot", "[", 
     RowBox[{"expr", ",", 
      RowBox[{"{", 
       RowBox[{"xVar", ",", "xMin", ",", "xMax"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
      RowBox[{"PlotRangePadding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Scaled", "[", "0.02", "]"}], ",", 
