Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"2.", " ", "EILERS"}], "-", 
    RowBox[{"PEETERS", " ", "FUNCTION", " ", 
     RowBox[{"(", "LIGHT", ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"lightData", "=", 
     RowBox[{"Import", "[", 
      RowBox[{
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"paramsDir", ",", "\"\<light_MBD_params.csv\>\""}], "}"}], 
        "]"}], ",", "\"\<Data\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mumaxL", "=", 
     RowBox[{"lightData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";", 
    RowBox[{"alphaL", "=", 
     RowBox[{"lightData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
    RowBox[{"ioptL", "=", 
     RowBox[{"lightData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"epExpr", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"mumax", "*", "light"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"mumax", "/", 
            RowBox[{"(", 
             RowBox[{"alpha", "*", 
              RowBox[{"iopt", "^", "2"}]}], ")"}]}], ")"}], "*", 
          RowBox[{"light", "^", "2"}]}], ")"}], "+", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", "*", "mumax"}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"alpha", "*", "iopt"}], ")"}]}]}], ")"}], "*", 
          "light"}], ")"}], "+", 
        RowBox[{"(", 
         RowBox[{"mumax", "/", "alpha"}], ")"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dMumaxEP", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"epExpr", ",", "mumax"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"mumax", "->", "mumaxL"}], ",", 
        RowBox[{"alpha", "->", "alphaL"}], ",", 
        RowBox[{"iopt", "->", "ioptL"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dAlphaEP", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"epExpr", ",", "alpha"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"mumax", "->", "mumaxL"}], ",", 
        RowBox[{"alpha", "->", "alphaL"}], ",", 
        RowBox[{"iopt", "->", "ioptL"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dIoptEP", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"epExpr", ",", "iopt"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"mumax", "->", "mumaxL"}], ",", 
        RowBox[{"alpha", "->", "alphaL"}], ",", 
        RowBox[{"iopt", "->", "ioptL"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"xLabelLight", "=", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<Light intensity (\[Mu]E \>\"", ",", 
        RowBox[{"Superscript", "[", 
         RowBox[{"\"\<m\>\"", ",", "\"\<-2\>\""}], "]"}], ",", "\"\< \>\"", ",", 
        RowBox[{"Superscript", "[", 
         RowBox[{"\"\<s\>\"", ",", "\"\<-1\>\""}], "]"}], ",", "\"\<)\>\""}], 
       "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"pL1", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dMumaxEP", ",", 
       RowBox[{"{", 
        RowBox[{"light", ",", "0", ",", "1000"}], "}"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<\[Mu]\>\"", ",", "\"\<max\>\""}], "]"}], ",", 
       "xLabelLight"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pL2", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dAlphaEP", ",", 
       RowBox[{"{", 
        RowBox[{"light", ",", "0", ",", "1000"}], "}"}], 
       ",", "\"\<\[Alpha]\>\"", ",", "xLabelLight"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pL3", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dIoptEP", ",", 
       RowBox[{"{", 
        RowBox[{"light", ",", "0", ",", "1000"}], "}"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<I\>\"", ",", "\"\<opt\>\""}], "]"}], ",", 
       "xLabelLight"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"plotLight", "=", 
    RowBox[{"Style", "[", 
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"pL1", ",", "pL2"}], "}"}], ",", 
            RowBox[{"{", "pL3", "}"}]}], "}"}], ",", 
          RowBox[{"Spacings", "->", 
           RowBox[{"{", 
            RowBox[{"2", ",", "0"}], "}"}]}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Sensitivity of Eilers-Peeters parameters\>\"", ",", 
          "24"}], "]"}], ",", "Top"}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Background", "->", "White"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{
        "basePath", ",", "\"\<Sensitivity_EilersPeeters_Light.pdf\>\""}], 
        "}"}], "]"}], ",", "plotLight"}], "]"}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.988914169418703*^9, 3.988914192234562*^9}, {
  3.988914672851222*^9, 3.9889146731277447`*^9}, {3.988914880952436*^9, 
  3.988914894492257*^9}, {3.988915240535644*^9, 3.9889152518299522`*^9}, {
  3.990634300297345*^9, 3.9906343015320177`*^9}, {3.990636149370202*^9, 
  3.9906361496762114`*^9}},
 CellLabel->
