Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"1.", " ", "MONOD", " ", "FUNCTION", " ", 
    RowBox[{"(", "NUTRIENTS", ")"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"monodData", "=", 
     RowBox[{"Import", "[", 
      RowBox[{
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"paramsDir", ",", "\"\<nutrient_MBD_params.csv\>\""}], "}"}],
         "]"}], ",", "\"\<Data\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"mumaxM", "=", 
     RowBox[{"monodData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kM", "=", 
     RowBox[{"monodData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"monodExpr", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"mumax", "*", "x"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"x", "+", "k"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dMumaxMonod", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"monodExpr", ",", "mumax"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"mumax", "->", "mumaxM"}], ",", 
        RowBox[{"k", "->", "kM"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dKMonod", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"monodExpr", ",", "k"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"mumax", "->", "mumaxM"}], ",", 
        RowBox[{"k", "->", "kM"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xLabelMonod", "=", 
     RowBox[{"Row", "[", 
      RowBox[{"{", "\"\<Nutrient concentration (\[Mu]M)\>\"", "}"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pM1", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dMumaxMonod", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "25"}], "}"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<\[Mu]\>\"", ",", "\"\<max\>\""}], "]"}], ",", 
       "xLabelMonod"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pM2", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dKMonod", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "25"}], "}"}], ",", "\"\<K\>\"", ",", 
       "xLabelMonod"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plotMonod", "=", 
    RowBox[{"Style", "[", 
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"pM1", ",", "pM2"}], "}"}], "}"}], ",", 
          RowBox[{"Spacings", "->", 
           RowBox[{"{", 
            RowBox[{"2", ",", "0"}], "}"}]}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Sensitivity of Monod parameters\>\"", ",", "24"}], 
         "]"}], ",", "Top"}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Background", "->", "White"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"basePath", ",", "\"\<Sensitivity_Monod_Nutrients.pdf\>\""}], 
        "}"}], "]"}], ",", "plotMonod"}], "]"}], ";"}]}]}]], "Input",
