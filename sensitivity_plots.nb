Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"4.", " ", "LOG"}], "-", 
    RowBox[{"LOGISTIC", " ", "FUNCTION", " ", 
     RowBox[{"(", "TOXINS", ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Note", " ", "that", " ", "this", " ", "is", " ", "on", " ", "a", " ", 
     "pseudo"}], "-", 
    RowBox[{"log", " ", "scale"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"1.", " ", "Define", " ", "the", " ", "R", " ", "pseudo"}], "-", 
    RowBox[{"log", " ", "transformation", " ", "mathematically"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sigma", "=", "0.1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"base", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"psLog", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"ArcSinh", "[", 
       RowBox[{"x", "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", "sigma"}], ")"}]}], "]"}], "/", 
      RowBox[{"Log", "[", "base", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"invPsLog", "[", "y_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Sinh", "[", 
       RowBox[{"y", "*", 
        RowBox[{"Log", "[", "base", "]"}]}], "]"}], "*", 
      RowBox[{"(", 
       RowBox[{"2", "*", "sigma"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Define", " ", "a", " ", "duplicate", " ", "plotting", " ", 
     "function", " ", "that", " ", "applies", " ", "the", " ", "custom", " ", 
     "scale"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MakeSensitivityPlotPseudoLog", "[", 
     RowBox[{"expr_", ",", 
      RowBox[{"{", 
       RowBox[{"xVar_", ",", "xMin_", ",", "xMax_"}], "}"}], ",", "title_", ",",
       "xLabel_"}], "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"Plot", "[", 
     RowBox[{"expr", ",", 
      RowBox[{"{", 
       RowBox[{"xVar", ",", "xMin", ",", "xMax"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ScalingFunctions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"psLog", ",", "invPsLog"}], "}"}], ",", "None"}], "}"}]}], ",", 
      RowBox[{"FrameTicks", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Automatic", ",", "None"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "\"\<0\>\""}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "\"\<1\>\""}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"10", ",", "\"\<10\>\""}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"100", ",", "\"\<100\>\""}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1000", ",", "\"\<1000\>\""}], "}"}]}], "}"}], ",", 
           "None"}], "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotRangePadding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Scaled", "[", "0.02", "]"}], ",", 
         RowBox[{"Scaled", "[", "0.08", "]"}]}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Axes", "->", "False"}], ",", "\[IndentingNewLine]", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\"\<Sensitivity\>\"", ",", "None"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"xLabel", ",", "title"}], "}"}]}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"Thickness", "[", "0.003", "]"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"GridLines", "->", 
       RowBox[{"{", 
        RowBox[{"None", ",", 
         RowBox[{"{", "0", "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"GridLinesStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", "Dashed", ",", 
         RowBox[{"AbsoluteThickness", "[", "1.5", "]"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"FrameStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"Thickness", "[", "0.002", "]"}]}], "]"}]}], ",", 
      RowBox[{"BaseStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FontSize", "->", "16"}], ",", 
         RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}], ",", 
         RowBox[{"FontColor", "->", "Black"}]}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ImagePadding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"85", ",", "20"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"60", ",", "20"}], "}"}]}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ImageSize", "->", "400"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Background", "->", "White"}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Data", " ", "imports", " ", "and", " ", "derivatives"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"toxinData", "=", 
     RowBox[{"Import", "[", 
      RowBox[{
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"paramsDir", ",", "\"\<toxin_MBD_params.csv\>\""}], "}"}], 
        "]"}], ",", "\"\<Data\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dM", "=", 
     RowBox[{"toxinData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";", 
    RowBox[{"eM", "=", 
     RowBox[{"toxinData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
    RowBox[{"hM", "=", 
     RowBox[{"toxinData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "3"}], "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"drExpr", "=", 
     RowBox[{"d", "/", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "/", "e"}], ")"}], "^", "h"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dD", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"drExpr", ",", "d"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"d", "->", "dM"}], ",", 
        RowBox[{"e", "->", "eM"}], ",", 
        RowBox[{"h", "->", "hM"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dH", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"drExpr", ",", "h"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"d", "->", "dM"}], ",", 
        RowBox[{"e", "->", "eM"}], ",", 
        RowBox[{"h", "->", "hM"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dE", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"drExpr", ",", "e"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"d", "->", "dM"}], ",", 
        RowBox[{"e", "->", "eM"}], ",", 
        RowBox[{"h", "->", "hM"}]}], "}"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xLabelToxin", "=", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<Toxin concentration (\[Mu]g \>\"", ",", 
        RowBox[{"Superscript", "[", 
         RowBox[{"\"\<L\>\"", ",", "\"\<-1\>\""}], "]"}], ",", "\"\<)\>\""}], 
       "}"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Call", " ", "the", " ", "new", " ", "function"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pDR1", "=", 
     RowBox[{"MakeSensitivityPlotPseudoLog", "[", 
      RowBox[{"dD", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1000"}], "}"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<\[Mu]\>\"", ",", "\"\<max\>\""}], "]"}], ",", 
       "xLabelToxin"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pDR2", "=", 
     RowBox[{"MakeSensitivityPlotPseudoLog", "[", 
      RowBox[{"dH", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1000"}], "}"}], ",", "\"\<h\>\"", ",", 
       "xLabelToxin"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pDR3", "=", 
     RowBox[{"MakeSensitivityPlotPseudoLog", "[", 
      RowBox[{"dE", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1000"}], "}"}], ",", "\"\<e\>\"", ",", 
       "xLabelToxin"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Combine", " ", "and", " ", "export"}], "*)"}], "\n", 
   RowBox[{"plotDR", "=", 
    RowBox[{"Style", "[", 
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"pDR1", ",", "pDR3"}], "}"}], ",", 
            RowBox[{"{", "pDR2", "}"}]}], "}"}], ",", 
          RowBox[{"Spacings", "->", 
           RowBox[{"{", 
            RowBox[{"2", ",", "0"}], "}"}]}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Sensitivity of dose-response parameters\>\"", ",", 
          "24"}], "]"}], ",", "Top"}], "]"}], ",", 
      RowBox[{"Background", "->", "White"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{
        "basePath", ",", "\"\<Sensitivity_DoseResponse_Toxins.pdf\>\""}], 
        "}"}], "]"}], ",", "plotDR"}], "]"}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
