      "\[IndentingNewLine]", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"Thickness", "[", "0.003", "]"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
