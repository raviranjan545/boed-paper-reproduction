Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", "NORBERG", " ", "FUNCTION", " ", 
    RowBox[{"(", "TEMPERATURE", ")"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "==="}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"tempData", "=", 
     RowBox[{"Import", "[", 
      RowBox[{
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"paramsDir", ",", "\"\<temperature_MBD_params.csv\>\""}], 
         "}"}], "]"}], ",", "\"\<Data\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"aM", "=", 
     RowBox[{"tempData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";", 
    RowBox[{"bM", "=", 
     RowBox[{"tempData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
    RowBox[{"tmaxM", "=", 
     RowBox[{"tempData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "3"}], "]"}], "]"}]}], ";", 
    RowBox[{"tminM", "=", 
     RowBox[{"tempData", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "4"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"norbergExpr", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "*", 
        RowBox[{"Exp", "[", 
         RowBox[{"b", "*", "temp"}], "]"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{"tmax", "-", "temp"}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{"temp", "-", "tmin"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dA", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"norbergExpr", ",", "a"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "->", "aM"}], ",", 
        RowBox[{"b", "->", "bM"}], ",", 
        RowBox[{"tmax", "->", "tmaxM"}], ",", 
        RowBox[{"tmin", "->", "tminM"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dB", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"norbergExpr", ",", "b"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "->", "aM"}], ",", 
        RowBox[{"b", "->", "bM"}], ",", 
        RowBox[{"tmax", "->", "tmaxM"}], ",", 
        RowBox[{"tmin", "->", "tminM"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dTmax", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"norbergExpr", ",", "tmax"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "->", "aM"}], ",", 
        RowBox[{"b", "->", "bM"}], ",", 
        RowBox[{"tmax", "->", "tmaxM"}], ",", 
        RowBox[{"tmin", "->", "tminM"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dTmin", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"norbergExpr", ",", "tmin"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "->", "aM"}], ",", 
        RowBox[{"b", "->", "bM"}], ",", 
        RowBox[{"tmax", "->", "tmaxM"}], ",", 
        RowBox[{"tmin", "->", "tminM"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"xLabelTemp", "=", 
     RowBox[{"Row", "[", 
      RowBox[{"{", "\"\<Temperature (\[Degree]C)\>\"", "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"pT1", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dA", ",", 
       RowBox[{"{", 
        RowBox[{"temp", ",", "5", ",", "34.9"}], "}"}], ",", "\"\<a\>\"", ",",
        "xLabelTemp"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pT2", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dB", ",", 
       RowBox[{"{", 
        RowBox[{"temp", ",", "5", ",", "34.9"}], "}"}], ",", "\"\<b\>\"", ",",
        "xLabelTemp"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pT3", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dTmax", ",", 
       RowBox[{"{", 
        RowBox[{"temp", ",", "5", ",", "34.9"}], "}"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<T\>\"", ",", "\"\<max\>\""}], "]"}], ",", "xLabelTemp"}],
       "]"}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Note", " ", "that", " ", "this", " ", "curve", " ", "can", " ", "change",
      " ", "its", " ", "shape", " ", "within", " ", "the", " ", "design", " ",
      "shape", " ", "under", " ", "some", " ", "parameter", " ", 
     "combinations"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"See", " ", "Section", " ", "6"}], ",", " ", 
     RowBox[{"SI", " ", "for", " ", "details"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pT4", "=", 
     RowBox[{"MakeSensitivityPlot", "[", 
      RowBox[{"dTmin", ",", 
       RowBox[{"{", 
        RowBox[{"temp", ",", "5", ",", "34.9"}], "}"}], ",", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<T\>\"", ",", "\"\<min\>\""}], "]"}], ",", "xLabelTemp"}],
       "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"plotTemp", "=", 
    RowBox[{"Style", "[", 
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"pT1", ",", "pT2"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"pT4", ",", "pT3"}], "}"}]}], "}"}], ",", 
          RowBox[{"Spacings", "->", 
           RowBox[{"{", 
            RowBox[{"2", ",", "2"}], "}"}]}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Sensitivity of Norberg parameters\>\"", ",", "24"}], 
         "]"}], ",", "Top"}], "]"}], ",", 
      RowBox[{"Background", "->", "White"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{
        "basePath", ",", "\"\<Sensitivity_Norberg_Temperature.pdf\>\""}], 
        "}"}], "]"}], ",", "plotTemp"}], "]"}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9889140251507673`*^9, 3.988914072375926*^9}, {
  3.988914216069625*^9, 3.988914237464443*^9}, {3.988915260270093*^9, 
  3.988915279392886*^9}, {3.990634317943055*^9, 3.990634318457116*^9}, {
